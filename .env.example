# SONIOX_API_KEY: Real-time multilingual STT (zh<->en). Required for live mode;
# if empty, the server runs MOCK mode.
SONIOX_API_KEY=""

# Default translation provider (OpenAI-compatible). You can switch providers
# from the app's top-right settings panel while the server is running.
# If the chosen provider's key is empty, translation falls back to Soniox's
# built-in two-way translation.
TRANSLATE_PROVIDER="mimo"   # mimo | deepseek

# DeepSeek (https://api.deepseek.com)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-v4-flash"

# Xiaomi MiMo UltraSpeed (https://api.xiaomimimo.com/v1) — ~1000 tok/s
MIMO_API_KEY=""
MIMO_MODEL="mimo-v2.5-pro-ultraspeed"

# Translation latency budget (ms): soft first-token deadline, then hard timeout.
TRANSLATE_FIRST_TOKEN_MS="1200"
TRANSLATE_TIMEOUT_MS="2500"

# Turn-complete idle timeout (ms): finalize a turn this long after the last token.
IDLE_PENDING_TRANSLATION_MS="2000"

# Soniox endpoint delay (ms, 500-3000): lower finalizes a turn sooner after speech
# stops. Don't set too low or thinking-pauses get cut mid-sentence.
SONIOX_MAX_ENDPOINT_DELAY_MS="1500"

# Force a sentence break once committed text reaches this many chars. Caps caption
# size for fast continuous speech (news) that never pauses. The client "断句" slider
# overrides this live per session.
SEGMENT_MAX_CHARS="120"

# Soniox reconnect attempts on dropped session.
SONIOX_MAX_RECONNECT="3"

# Optional hard cap on audio seconds forwarded to Soniox per connection (budget guard).
# MAX_SESSION_AUDIO_SEC="3600"

# PORT: HTTP/WS port (default 3000).
PORT="3000"
